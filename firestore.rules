rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "gm.mominur.ahmed@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'customer'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'stock']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status']) &&
             (data.userId == 'guest' || (isAuthenticated() && data.userId == request.auth.uid)) &&
             data.items is list &&
             data.totalAmount is number &&
             data.status in ['incomplete', 'pending', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin())) || 
                     (resource.data.userId == 'guest'); // Allow guest to read their own if they have the ID (simplified)
      allow create: if (isAuthenticated() || request.resource.data.userId == 'guest') && isValidOrder(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid && isValidOrder(request.resource.data));
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if settingId != 'courier' || isAdmin();
      allow write: if isAdmin();
    }

    match /offerSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
